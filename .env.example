# ---- Topology (override to scale the demo) ----
API_REPLICAS=2
RT_PODS=3

# ---- Fanout strategy ----
# Clubs with memberCount <= PUSH_THRESHOLD use PUSH (materialize per-user feeds).
# Clubs above it use PULL (merge club_timeline at read time). This is the core decision.
PUSH_THRESHOLD=5000
# Only materialize users active in the last N days (the highest-ROI optimization).
ACTIVE_DAYS=7

# ---- Whale club seed (the spike target) ----
WHALE_MEMBERS=500000
SMALL_MEMBERS=1200

# ---- Infra endpoints (used inside the compose network) ----
REDIS_URL=redis://redis:6379
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=feed
MYSQL_PASSWORD=feedpw
MYSQL_DATABASE=activity
DYNAMO_ENDPOINT=http://dynamodb:8000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# ---- Drain / relay tuning ----
DRAIN_BATCH=256
RELAY_BATCH=256
RELAY_POLL_MS=50

# ---- Load generator defaults ----
LOAD_RATE=2000
LOAD_SECONDS=20
LOAD_CLUB=whale
